# ElectroLeaf Environment Variables

# API Configuration
# The base URL for the backend API server
# Used for all API calls including GraphQL, REST endpoints, and file uploads
# Default: http://localhost:8000 (local development)
# Production: Replace with your production API endpoint
REACT_APP_API_HOST=http://localhost:8000

# File Storage Configuration
# The base URL for accessing uploaded files and media assets
# Used to construct URLs for images and documents stored on the server
# Default: http://localhost:8000/uploads/ (local development)
# Production: Replace with your production file storage endpoint
REACT_APP_FILE_FOLDER=http://localhost:8000/uploads/