# ============================================
# Application Configuration
# ============================================

# Client ID for application identification
CLIENT_ID = electroleaf_dev

# Server port where the API will run
PORT = 8000

# ============================================
# Database Configuration
# ============================================

# MongoDB connection string
# Format: mongodb+srv://username:password@cluster.mongodb.net/database?retryWrites=true&w=majority
DB_CONNECT = mongodb+srv://user:password@cluster.mongodb.net/electro-leaf?retryWrites=true&w=majority

# ============================================
# JWT Secrets (Authentication)
# ============================================

# Secret key for signing access tokens (use a strong random string)
ACCESS_TOKEN_SECRET = your_access_token_secret_here

# Secret key for signing refresh tokens (use a strong random string)
REFRESH_TOKEN_SECRET = your_refresh_token_secret_here

# ============================================
# MQTT Configuration
# ============================================

# MQTT broker URL
# Public broker example: mqtt://broker.hivemq.com
# Local broker example: mqtt://localhost:1883
MQTT_BROKER = mqtt://broker.hivemq.com

# Topic prefix for MQTT messages
MQTT_PREFIX = ELF_IOT/dev

# ============================================
# External Services
# ============================================

# Python server URL for Flask integration
PYTHON_SERVER = http://localhost:5000

# Frontend domain URL for CORS and redirects
FROENTEND_DOMAIN = http://localhost:3000

# Path for password reset endpoint
PASSWORD_RESET_PATH = resetpassword

# ============================================
# Sensor and Tank Data Logging
# ============================================

# Enable/disable storing sensor readings in database
STORE_SENSOR_READINGS = true


# ============================================
# Email Configuration (Google OAuth)
# ============================================

# Email address for sending notifications
EMAIL_ADDRESS = your-email@gmail.com

# Google OAuth Client ID
EMAIL_CLIENT_ID = your_client_id.apps.googleusercontent.com

# Google OAuth Client Secret
EMAIL_CLIENT_SECRET = your_client_secret

# Google OAuth Redirect URI (usually the OAuth Playground for testing)
EMAIL_REDIRECT_URI = https://developers.google.com/oauthplayground

# Google OAuth Refresh Token (obtained after initial authorization)
EMAIL_REFERESH_TOKEN = your_refresh_token

# ============================================
# ImageKit Configuration (Image Storage)
# ============================================

# ImageKit URL endpoint for image delivery
IMAGEKIT_URLENDPOINT = https://ik.imagekit.io/your_id/

# ImageKit public key for client-side operations
IMAGEKIT_PUBLICKEY = public_key_here

# ImageKit private key for server-side operations (keep secure)
IMAGEKIT_PRIVATEKEY = private_key_here

# ============================================
# Farm Configuration
# ============================================

# Name of the farm/project
FARM_NAME = Development Farm

# Logo filename for the farm (should be in assets/logos/)
FARM_LOGO = dev.png